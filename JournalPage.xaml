<Window x:Class="NOT_VE_GÜNLÜK.JournalPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Günlük" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource JournalBackground}">
    
    <Grid Margin="0,0,0,-6">
        <!-- Arkaplan Katmanı (Overlay) -->
        <Border Background="{DynamicResource JournalOverlay}"/>
        
        <!-- Tarih ve Ayarlar -->
        <Grid Height="80" VerticalAlignment="Top" Margin="40,20,40,0">
            <!-- Geri Butonu (En Sol) -->
            <Button x:Name="btnBack" HorizontalAlignment="Left" Margin="0,0,0,0"
                    Width="35" Height="35" Background="Transparent" 
                    BorderThickness="0" Cursor="Hand"
                    Click="Back_Click">
                <TextBlock Text="←" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource JournalSecondaryForeground}"/>
            </Button>

            <!-- Ayarlar İkonu (Geri butonunun yanında) -->
            <Button x:Name="btnSettings" HorizontalAlignment="Left" Margin="50,0,0,0"
                    Width="35" Height="35" Background="Transparent" 
                    BorderThickness="0" Cursor="Hand"
                    Click="Settings_Click">
                <TextBlock Text="⚙️" FontSize="20"/>
            </Button>

            <!-- Tarih ve Tema Butonları (Sağ Üst) -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Tema Butonları -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                    <Button x:Name="btnLightTheme" Content="☀️" FontSize="20" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="Theme_Click" Tag="Light" Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTheme}" Value="Light">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnDarkTheme" Content="🌙" FontSize="20" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="Theme_Click" Tag="Dark">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTheme}" Value="Dark">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                
                <!-- Tarih -->
                <TextBlock x:Name="txtDate" Text="2 Ocak 2026" FontSize="16" 
                           Foreground="{DynamicResource JournalSecondaryForeground}" 
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- Gün Başlığı veya "Bugüne isim ver" Butonu -->
        <StackPanel VerticalAlignment="Top" Margin="40,110,40,0">
            <StackPanel Orientation="Horizontal" x:Name="pnlDayTitle" Visibility="Collapsed" Margin="0,0,0,30">
                <TextBlock x:Name="txtDayTitle" Text="" FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource JournalForeground}"/>
                <Button x:Name="btnEditTitle" Content="✏️" FontSize="20" Margin="15,0,0,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        VerticalAlignment="Center" Click="NameDay_Click" Opacity="0.5">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            
            <Button x:Name="btnNameDay" Content="Bugüne isim ver" FontSize="16"
                    Foreground="{DynamicResource JournalSecondaryForeground}" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Left" Padding="0" Margin="0,0,0,30"
                    Cursor="Hand" Click="NameDay_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource JournalForeground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Yazı Alanı -->
        <TextBox x:Name="txtContent" Margin="40,200,40,100" 
                 FontSize="15" Foreground="{DynamicResource JournalForeground}" 
                 Background="Transparent" BorderThickness="0"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Hidden"
                 Padding="0" FontFamily="Segoe UI"
                 CaretBrush="{DynamicResource JournalForeground}"
                 TextChanged="txtContent_TextChanged"/>


        <!-- Alt Navigasyon -->
        <Grid Height="60" VerticalAlignment="Bottom" Margin="40,0,40,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Önceki Gün" FontSize="14"
                    HorizontalAlignment="Left" Background="{DynamicResource JournalButtonBackground}" 
                    Foreground="{DynamicResource JournalForeground}" BorderThickness="0" Padding="20,12"
                    Cursor="Hand" Click="PreviousDay_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource JournalButtonHover}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="1" Content="Sonraki Gün →" FontSize="14"
                    HorizontalAlignment="Right" Background="{DynamicResource JournalButtonBackground}" 
                    Foreground="{DynamicResource JournalForeground}" BorderThickness="0" Padding="20,12"
                    Cursor="Hand" Click="NextDay_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource JournalButtonHover}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
